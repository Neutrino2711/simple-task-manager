# Lambda API Base URL
# Replace this with your actual AWS API Gateway endpoint
# Example: https://abc123def456.execute-api.us-east-1.amazonaws.com/stage/tasks
REACT_APP_API_BASE_URL=https://your-api-gateway-url/tasks

# Cognito Configuration
# Replace with your actual Cognito User Pool details
REACT_APP_COGNITO_AUTHORITY=https://cognito-idp.{region}.amazonaws.com/{user-pool-id}
REACT_APP_COGNITO_CLIENT_ID=your-client-id
REACT_APP_COGNITO_REDIRECT_URI=https://your-app-domain.com/
REACT_APP_COGNITO_LOGOUT_URI=https://your-app-domain.com/login
